<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ reportTitle }} — {{ institution.name }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    @page { size: A4; margin: 16mm 14mm 16mm 14mm; }

    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      font-size: 10.5px;
      color: #1a1a2e;
      background: #fff;
      line-height: 1.5;
    }

    /* ══ LETTERHEAD ══════════════════════════════════════════════════════════ */
    .letterhead {
      display: flex;
      align-items: center;
      justify-content: center;
      border-bottom: 3px solid #1a3c6e;
      padding-bottom: 10px;
      margin-bottom: 5px;
      gap: 16px;
    }

    .letterhead-logo-img {
      width: 62px;
      height: 62px;
      object-fit: contain;
      border-radius: 6px;
      flex-shrink: 0;
    }

    .letterhead-logo-placeholder {
      width: 62px;
      height: 62px;
      border-radius: 50%;
      background: linear-gradient(135deg, #1a3c6e, #2e6da4);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 22px;
      font-weight: 800;
      flex-shrink: 0;
    }

    .letterhead-text { text-align: center; }
    .institution-name { font-size: 18px; font-weight: 800; color: #1a3c6e; text-transform: uppercase; }
    .institution-short { font-size: 11px; color: #3a5f9e; font-weight: 600; margin-top: 1px; }
    .institution-meta { font-size: 8.5px; color: #666; margin-top: 3px; }

    /* ══ REPORT TITLE ══════════════════════════════════════════════════════════ */
    .report-title-block { text-align: center; margin: 8px 0 11px; }
    .report-category-badge {
      display: inline-block; background: #e8f0fe; color: #1a3c6e; font-size: 8px; font-weight: 700;
      letter-spacing: 1.2px; text-transform: uppercase; padding: 2px 10px; border-radius: 10px; border: 1px solid #c5d8f5; margin-bottom: 4px;
    }
    .report-title { font-size: 14px; font-weight: 700; color: #1a3c6e; border-bottom: 2px solid #3a5f9e; display: inline-block; padding: 0 20px 2px; }

    /* ══ META STRIP ═══════════════════════════════════════════════════════════ */
    .meta-strip {
      display: flex; justify-content: space-between; align-items: center; background: #f5f8ff;
      border: 1px solid #dce8f8; border-radius: 4px; padding: 5px 12px; margin-bottom: 13px; font-size: 9px; color: #444;
    }
    .meta-strip strong { color: #1a3c6e; }

    /* ══ GROUP HEADER ═════════════════════════════════════════════════════════ */
    .group-section { margin-bottom: 20px; page-break-inside: avoid; }
    .group-header {
      background: #fff; padding: 8px 0; font-size: 11px; font-weight: 700; color: #1a3c6e;
      border-top: 1px solid #eee; margin-top: 10px;
    }
    .group-header span { color: #555; font-weight: 400; margin-right: 5px; }

    /* ══ DATA TABLE ════════════════════════════════════════════════════════════ */
    .report-table { width: 100%; border-collapse: collapse; font-size: 9px; margin-top: 4px; border: 1px solid #1a3c6e; }
    .report-table thead { background: #dce8f8; color: #1a3c6e; }
    .report-table thead th {
      padding: 6px 8px; text-align: left; font-weight: 700; font-size: 8.5px;
      border: 1px solid #1a3c6e; text-transform: uppercase;
    }
    .report-table tbody td { padding: 4px 8px; border: 1px solid #ddd; color: #2d2d2d; border-right: 1px solid #1a3c6e; border-left: 1px solid #1a3c6e; border-bottom: 1px solid #1a3c6e; }
    .report-table tbody tr:nth-child(even) { background: #f9f9f9; }

    /* ══ FOOTER ════════════════════════════════════════════════════════════════ */
    .report-footer { margin-top: 20px; border-top: 2px solid #1a3c6e; padding-top: 10px; }
    .footer-signatures { display: flex; justify-content: space-between; align-items: flex-end; font-size: 8.5px; color: #555; }
    .signature-block { text-align: center; min-width: 130px; }
    .signature-line { border-top: 1px solid #444; margin-top: 28px; padding-top: 4px; font-size: 8px; color: #333; }
    .footer-center { text-align: center; font-size: 8px; color: #888; }
    .footer-institution-info { text-align: center; font-size: 7.5px; color: #777; margin-top: 6px; }

    @media print {
      .report-table thead { display: table-header-group; }
      tr { page-break-inside: avoid; }
    }
  </style>
</head>
<body>

  <!-- LETTERHEAD -->
  <div class="letterhead">
    {{#if institution.logo}}
      <img class="letterhead-logo-img" src="{{ institution.logo }}" alt="logo" />
    {{else}}
      <div class="letterhead-logo-placeholder">{{ institution.name.[0] }}</div>
    {{/if}}
    <div class="letterhead-text">
      <div class="institution-name">{{ institution.name }}</div>
      {{#if institution.shortName}}<div class="institution-short">{{ institution.shortName }}</div>{{/if}}
      <div class="institution-meta">
        {{ institution.address }} | {{ institution.email }} | {{ institution.phone }}
      </div>
    </div>
  </div>

  <div class="report-title-block">
    <div class="report-title">{{ reportTitle }}</div>
  </div>

  <div class="meta-strip">
    <span><strong>Department:</strong> {{#if dateFrom}}All{{else}}Selected{{/if}}</span>
    <span><strong>Records:</strong> {{ totalRecords }}</span>
    <span><strong>Generated:</strong> {{ generatedOn }}</span>
  </div>

  {{#if hasRows}}
    {{#if isGrouped}}
      {{#each rows}}
      <div class="group-section">
        <div class="group-header"><span>Department:</span> {{ this.groupValue }}</div>
        <table class="report-table">
          <thead>
            <tr>
              <th style="width:30px;">Si No</th>
              {{#each ../columns}}<th>{{ this }}</th>{{/each}}
            </tr>
          </thead>
          <tbody>
            {{#each this.rows}}
            <tr>
              <td style="text-align:center;">{{ rowIndex @index }}</td>
              {{#each this}}<td>{{ str this }}</td>{{/each}}
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{/each}}
    {{else}}
      <table class="report-table">
        <thead>
          <tr>
            <th style="width:30px;">Si No</th>
            {{#each columns}}<th>{{ this }}</th>{{/each}}
          </tr>
        </thead>
        <tbody>
          {{#each rows}}
          <tr>
            <td style="text-align:center;">{{ rowIndex @index }}</td>
            {{#each this}}<td>{{ str this }}</td>{{/each}}
          </tr>
          {{/each}}
        </tbody>
      </table>
    {{/if}}
  {{else}}
    <div style="text-align:center; padding: 40px; color: #999;">No records found for the selected criteria.</div>
  {{/if}}

    <!-- FOOTER -->
  <div class="report-footer" style="margin-top: 18px; border-top: 2px solid #0d6e4e; padding-top: 10px; display: flex; justify-content: space-between; align-items: flex-end; font-size: 8px; color: #555;">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;width:100%;">
      <!-- Left Signature (HOD or Admin) -->
      <div class="signature-block" style="text-align: center; min-width: 130px;">
        <div class="signature-name" style="font-weight: 700; font-size: 10px; color: #000; margin-bottom: 3px;">{{ signatureInfo.leftName }}</div>
        <div class="signature-line" style="border-top: 1px solid #444; padding-top: 4px; font-size: 8px; font-weight: bold;">{{ signatureInfo.leftTitle }}</div>
        {{#if signatureInfo.leftSubtitle}}<div style="font-size: 8px; padding-top: 2px; font-weight: bold;">{{ signatureInfo.leftSubtitle }}</div>{{/if}}
      </div>
      
      <!-- Center Info -->
      <div class="footer-center" style="text-align: center; font-size: 7.5px; color: #888; flex: 1; padding: 0 10px;">
        {{ institution.name }}<br/><span style="color:#aaa;">System-generated &nbsp;|&nbsp; HRMS</span>
      </div>
      
      <!-- Right Signature (Principal) -->
      <div class="signature-block" style="text-align: center; min-width: 130px;">
        <div class="signature-name" style="font-weight: 700; font-size: 10px; color: #000; margin-bottom: 3px;">&nbsp;</div>
        <div class="signature-line" style="border-top: 1px solid #444; padding-top: 4px; font-size: 8px; font-weight: bold;">{{ signatureInfo.rightName }}</div>
        <div style="font-size: 8px; padding-top: 2px; font-weight: bold;">{{ signatureInfo.rightSubtitle }}</div>
      </div>
    </div>
  </div>

</body>
</html>
