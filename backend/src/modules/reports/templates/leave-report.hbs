<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ reportTitle }} — {{ institution.name }}</title>
  <!-- Leave Report (Purple Theme) -->
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    @page { size: A4; margin: 18mm 15mm 18mm 15mm; }

    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      font-size: 10.5px;
      color: #1a1a2e;
      background: #fff;
      line-height: 1.5;
    }

    /* ── Letterhead ─── */
    .letterhead {
      display: flex;
      align-items: center;
      justify-content: center;
      border-bottom: 3px solid #7b2d8b;
      padding-bottom: 10px;
      margin-bottom: 6px;
      gap: 14px;
    }
    .letterhead-logo-img { width: 60px; height: 60px; object-fit: contain; border-radius: 6px; flex-shrink: 0; }
    .letterhead-logo-placeholder {
      width: 60px; height: 60px;
      border-radius: 50%;
      background: linear-gradient(135deg, #7b2d8b, #a855b5);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 22px; font-weight: 800; flex-shrink: 0;
    }
    .letterhead-text { text-align: center; }
    .institution-name { font-size: 18px; font-weight: 800; color: #7b2d8b; letter-spacing: 0.5px; text-transform: uppercase; }
    .institution-short { font-size: 11px; color: #9b3dab; font-weight: 600; margin-top: 1px; }
    .institution-tagline { font-size: 8.5px; color: #555; margin-top: 2px; }
    .institution-meta { font-size: 8px; color: #666; margin-top: 2px; }
    .footer-institution-info { text-align: center; font-size: 7.5px; color: #777; margin-top: 6px; }

    /* ── Report Title ─── */
    .report-title-block { text-align: center; margin: 8px 0 12px; }
    .report-category-badge {
      display: inline-block;
      background: #f5e8ff; color: #7b2d8b; font-size: 8px; font-weight: 700;
      letter-spacing: 1.2px; text-transform: uppercase;
      padding: 2px 10px; border-radius: 10px; border: 1px solid #ddb8f0; margin-bottom: 4px;
    }
    .report-title { font-size: 14px; font-weight: 700; color: #7b2d8b; }

    /* ── Meta Strip ─── */
    .meta-strip {
      display: flex; justify-content: space-between; align-items: center;
      background: #fdf4ff; border: 1px solid #e8c8f6; border-radius: 4px;
      padding: 5px 12px; margin-bottom: 14px; font-size: 9px; color: #444;
    }
    .meta-strip strong { color: #7b2d8b; }

    /* ── Leave Summary Cards ─── */
    .summary-cards {
      display: flex; gap: 10px; margin-bottom: 14px; flex-wrap: wrap;
    }
    .summary-card {
      flex: 1; min-width: 80px;
      background: #f8f0ff; border: 1px solid #e0b8f8; border-radius: 6px;
      padding: 8px 12px; text-align: center;
    }
    .summary-card .card-value { font-size: 20px; font-weight: 800; color: #7b2d8b; }
    .summary-card .card-label { font-size: 8px; color: #666; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; }

    /* ── Table ─── */
    .report-table {
      width: 100%; border-collapse: collapse; font-size: 9.5px; page-break-inside: auto;
    }
    .report-table thead { background: #7b2d8b; color: #fff; }
    .report-table thead th {
      padding: 7px 8px; text-align: left; font-weight: 600; font-size: 9px;
      border-right: 1px solid #9b3dab; white-space: nowrap;
    }
    .report-table thead th:last-child { border-right: none; }
    .report-table tbody tr { page-break-inside: avoid; }
    .report-table tbody tr:nth-child(even) { background: #fdf4ff; }
    .report-table tbody tr:nth-child(odd)  { background: #fff; }
    .report-table tbody td {
      padding: 5px 8px; border-bottom: 1px solid #ead5f8;
      border-right: 1px solid #f2e4fc; color: #2d2d2d; vertical-align: middle;
    }
    .report-table tbody td:last-child { border-right: none; }

    /* ── Status Badges ─── */
    .badge {
      display: inline-block; padding: 1px 7px; border-radius: 10px;
      font-size: 8px; font-weight: 600; text-transform: uppercase;
    }
    .badge-approved { background: #d4edda; color: #1a6b35; }
    .badge-pending  { background: #fff3cd; color: #856404; }
    .badge-rejected { background: #f8d7da; color: #842029; }

    /* ── Summary Row ─── */
    .summary-row { background: #f5e8ff !important; font-weight: 700; color: #7b2d8b; }

    /* ── Empty State ─── */
    .empty-state { text-align: center; padding: 40px 0; color: #888; font-size: 11px; }

    /* ── Footer ─── */
    .report-footer {
      margin-top: 20px; border-top: 2px solid #7b2d8b; padding-top: 10px;
      display: flex; justify-content: space-between; align-items: flex-end;
      font-size: 8.5px; color: #555;
    }
    .signature-block { text-align: center; min-width: 130px; }
    .signature-line {
      border-top: 1px solid #444; margin-top: 28px;
      padding-top: 4px; font-size: 8px; color: #333;
    }
    .footer-center { text-align: center; font-size: 8px; color: #888; }
    @media print { .report-table thead { display: table-header-group; } tr { page-break-inside: avoid; } }
  </style>
</head>
<body>

  <!-- LETTERHEAD -->
  <div class="letterhead">
    {{#if institution.logo}}
      <img class="letterhead-logo-img" src="{{ institution.logo }}" alt="{{ institution.name }}" />
    {{else}}
      <div class="letterhead-logo-placeholder">{{ institution.name.[0] }}</div>
    {{/if}}
    <div class="letterhead-text">
      <div class="institution-name">{{ institution.name }}</div>
      {{#if institution.shortName}}<div class="institution-short">{{ institution.shortName }}</div>{{/if}}
      <div class="institution-tagline">Human Resource Management System{{#if institution.code}} &nbsp;|&nbsp; {{ institution.code }}{{/if}}</div>
      {{#if institution.address}}<div class="institution-meta">{{ institution.address }}</div>{{/if}}
      {{#if institution.email}}<div class="institution-meta">✉ {{ institution.email }}{{#if institution.phone}} &nbsp;|&nbsp; ☎ {{ institution.phone }}{{/if}}</div>{{/if}}
    </div>
  </div>

  <!-- TITLE -->
  <div class="report-title-block">
    <div class="report-category-badge">LEAVE REPORT</div>
    <div class="report-title">{{ reportTitle }}</div>
  </div>

  <!-- META STRIP -->
  <div class="meta-strip">
    <span><strong>Total Records:</strong> {{ totalRecords }}</span>
    {{#if dateFrom}}
    <span><strong>Period:</strong> {{ dateFrom }} → {{#if dateTo}}{{ dateTo }}{{else}}Today{{/if}}</span>
    {{/if}}
    <span><strong>Generated:</strong> {{ generatedOn }}</span>
  </div>

  <!-- SUMMARY CARDS -->
  {{#if hasRows}}
  <div class="summary-cards">
    <div class="summary-card">
      <div class="card-value">{{ totalRecords }}</div>
      <div class="card-label">Total Applications</div>
    </div>
    <div class="summary-card">
      <div class="card-value" style="color:#1a6b35;">—</div>
      <div class="card-label">Approved</div>
    </div>
    <div class="summary-card">
      <div class="card-value" style="color:#856404;">—</div>
      <div class="card-label">Pending</div>
    </div>
    <div class="summary-card">
      <div class="card-value" style="color:#842029;">—</div>
      <div class="card-label">Rejected</div>
    </div>
  </div>
  {{/if}}

  <!-- TABLE -->
  {{#if hasRows}}
  <table class="report-table">
    <thead>
      <tr>
        <th style="width:28px;">#</th>
        {{#each columns}}<th>{{ this }}</th>{{/each}}
      </tr>
    </thead>
    <tbody>
      {{#each rows}}
      <tr>
        <td style="color:#888;text-align:center;">{{ rowIndex @index }}</td>
        {{#each this}}<td>{{ str this }}</td>{{/each}}
      </tr>
      {{/each}}
      <tr class="summary-row">
        <td></td>
        <td colspan="{{ columns.length }}">Total: {{ totalRecords }} record(s)</td>
      </tr>
    </tbody>
  </table>
  {{else}}
  <div class="empty-state">No leave records found for the selected filters.</div>
  {{/if}}

  <!-- FOOTER -->
  <div class="report-footer">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;">
      <div class="signature-block"><div class="signature-line">HR Officer</div></div>
      <div class="footer-center">{{ institution.name }}<br/><span style="color:#aaa;">System-generated &nbsp;|&nbsp; HRMS</span></div>
      <div class="signature-block"><div class="signature-line">Principal / Director</div></div>
    </div>
    {{#if institution.address}}<div class="footer-institution-info">{{ institution.address }}{{#if institution.email}} &nbsp;|&nbsp; {{ institution.email }}{{/if}}</div>{{/if}}
  </div>

</body>
</html>
